<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <meta name="description" content="Havenco — Premium home goods delivered across the UAE in 3–7 days. Secure checkout. Free returns on defective items."/>
  <title>Havenco · UAE Home Goods</title>

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garant:ital,wght@0,300;0,400;0,500;0,600;0,700;1,300;1,400;1,600&family=Jost:wght@200;300;400;500;600&display=swap" rel="stylesheet">

  <style>
    /* ─────────────────────────────────────
       TOKENS
    ───────────────────────────────────── */
    :root {
      --ivory:     #FAF7F2;
      --ivory-2:   #F2EDE4;
      --ivory-3:   #E8E0D5;
      --parch:     #EDE8DF;
      --gold:      #B8964E;
      --gold-lt:   #D4AE6A;
      --gold-dk:   #947838;
      --charcoal:  #1C1A18;
      --ink:       #2C2825;
      --ink-2:     #4A453F;
      --mist:      #8C857C;
      --mist-lt:   #B8B0A6;
      --rule:      rgba(184,150,78,.22);
      --rule-lt:   rgba(184,150,78,.10);
      --shadow-sm: 0 2px 16px rgba(28,26,24,.06);
      --shadow-md: 0 8px 40px rgba(28,26,24,.10);
      --shadow-lg: 0 20px 60px rgba(28,26,24,.13);

      --f-display: 'Cormorant Garant', Georgia, serif;
      --f-body:    'Jost', sans-serif;

      --ease:     cubic-bezier(.22,.68,0,1.2);
      --ease-out: cubic-bezier(.16,1,.3,1);
    }

    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { scroll-behavior: smooth; }
    body {
      background: var(--ivory);
      color: var(--ink);
      font-family: var(--f-body);
      font-weight: 300;
      line-height: 1.7;
      overflow-x: hidden;
    }
    a { color: inherit; text-decoration: none; }

    /* ─────────────────────────────────────
       ANIMATIONS
    ───────────────────────────────────── */
    @keyframes fadeUp {
      from { opacity:0; transform:translateY(24px); }
      to   { opacity:1; transform:translateY(0); }
    }
    @keyframes fadeIn {
      from { opacity:0; } to { opacity:1; }
    }
    @keyframes shimmer {
      0%   { background-position: -400px 0; }
      100% { background-position: 400px 0; }
    }
    @keyframes ticker {
      from { transform: translateX(0); }
      to   { transform: translateX(-50%); }
    }
    @keyframes pulse {
      0%,100% { opacity:1; } 50% { opacity:.5; }
    }

    .reveal {
      opacity: 0;
      transform: translateY(28px);
      transition: opacity .7s var(--ease-out), transform .7s var(--ease-out);
    }
    .reveal.in { opacity:1; transform:translateY(0); }
    .d1 { transition-delay:.08s; }
    .d2 { transition-delay:.16s; }
    .d3 { transition-delay:.24s; }
    .d4 { transition-delay:.32s; }

    /* ─────────────────────────────────────
       ANNOUNCEMENT STRIP
    ───────────────────────────────────── */
    .strip {
      background: var(--charcoal);
      padding: 9px 0;
      overflow: hidden;
    }
    .strip-track {
      display: inline-block;
      white-space: nowrap;
      animation: ticker 38s linear infinite;
    }
    .strip-track span {
      font-family: var(--f-body);
      font-size: 11px;
      font-weight: 500;
      letter-spacing: .18em;
      text-transform: uppercase;
      color: var(--gold-lt);
      margin: 0 52px;
    }
    .strip-track span::before { content: '✦  '; }

    /* ─────────────────────────────────────
       NAV
    ───────────────────────────────────── */
    nav {
      position: sticky;
      top: 0;
      z-index: 200;
      background: rgba(250,247,242,.94);
      backdrop-filter: blur(20px);
      -webkit-backdrop-filter: blur(20px);
      border-bottom: 1px solid var(--rule-lt);
      height: 64px;
      display: flex;
      align-items: center;
      padding: 0 6%;
      gap: 40px;
    }

    .nav-logo {
      display: flex;
      flex-direction: column;
      gap: 0;
      margin-right: auto;
    }
    .nav-logo-word {
      font-family: var(--f-display);
      font-size: 22px;
      font-weight: 600;
      color: var(--charcoal);
      letter-spacing: .06em;
      line-height: 1;
    }
    .nav-logo-sub {
      font-family: var(--f-body);
      font-size: 9px;
      font-weight: 500;
      letter-spacing: .28em;
      text-transform: uppercase;
      color: var(--gold);
      margin-top: 2px;
    }

    .nav-links {
      display: flex;
      align-items: center;
      gap: 32px;
      list-style: none;
    }
    .nav-links a {
      font-size: 11px;
      font-weight: 500;
      letter-spacing: .14em;
      text-transform: uppercase;
      color: var(--ink-2);
      transition: color .2s;
    }
    .nav-links a:hover { color: var(--gold); }

    .nav-checkout {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      background: var(--charcoal);
      color: var(--ivory) !important;
      font-size: 10px !important;
      font-weight: 600 !important;
      letter-spacing: .16em !important;
      padding: 9px 20px;
      border-radius: 2px;
      transition: background .2s !important;
    }
    .nav-checkout:hover { background: var(--ink-2) !important; color: var(--ivory) !important; }

    .hamburger {
      display: none;
      flex-direction: column;
      gap: 5px;
      background: none;
      border: none;
      cursor: pointer;
      padding: 4px;
      margin-left: auto;
    }
    .hamburger span {
      display: block;
      width: 22px;
      height: 1.5px;
      background: var(--charcoal);
      transition: transform .25s;
    }

    .mob-nav {
      display: none;
      position: fixed;
      top: 64px;
      left: 0; right: 0;
      background: var(--ivory);
      border-bottom: 1px solid var(--rule-lt);
      padding: 24px 6%;
      flex-direction: column;
      gap: 18px;
      z-index: 199;
    }
    .mob-nav.open { display: flex; }
    .mob-nav a {
      font-size: 12px;
      font-weight: 500;
      letter-spacing: .14em;
      text-transform: uppercase;
      color: var(--ink-2);
      padding-bottom: 14px;
      border-bottom: 1px solid var(--rule-lt);
    }

    /* ─────────────────────────────────────
       HERO
    ───────────────────────────────────── */
    .hero {
      min-height: calc(100svh - 64px);
      display: flex;
      align-items: center;
      position: relative;
      padding: 80px 6% 80px;
      overflow: hidden;
    }

    /* warm grain texture */
    .hero::before {
      content: '';
      position: absolute;
      inset: 0;
      background:
        radial-gradient(ellipse 70% 60% at 75% 50%, rgba(184,150,78,.07) 0%, transparent 65%),
        radial-gradient(ellipse 50% 80% at 10% 80%, rgba(184,150,78,.05) 0%, transparent 55%);
      pointer-events: none;
    }

    /* decorative vertical rule */
    .hero::after {
      content: '';
      position: absolute;
      top: 10%;
      bottom: 10%;
      right: 42%;
      width: 1px;
      background: linear-gradient(to bottom, transparent, var(--rule), var(--rule), transparent);
    }

    .hero-left {
      position: relative;
      z-index: 1;
      max-width: 580px;
    }

    .hero-eyebrow {
      display: inline-flex;
      align-items: center;
      gap: 12px;
      font-family: var(--f-body);
      font-size: 10px;
      font-weight: 600;
      letter-spacing: .24em;
      text-transform: uppercase;
      color: var(--gold);
      margin-bottom: 28px;
      animation: fadeUp .7s var(--ease-out) both;
    }
    .hero-eyebrow::before {
      content: '';
      display: block;
      width: 28px;
      height: 1px;
      background: var(--gold);
    }

    .hero-h1 {
      font-family: var(--f-display);
      font-weight: 300;
      font-size: clamp(44px, 7vw, 80px);
      line-height: 1.05;
      color: var(--charcoal);
      letter-spacing: -.01em;
      margin-bottom: 28px;
      animation: fadeUp .7s .08s var(--ease-out) both;
    }
    .hero-h1 em {
      font-style: italic;
      font-weight: 400;
      color: var(--gold-dk);
    }

    .hero-sub {
      font-size: 16px;
      font-weight: 300;
      color: var(--ink-2);
      max-width: 420px;
      line-height: 1.8;
      margin-bottom: 44px;
      animation: fadeUp .7s .16s var(--ease-out) both;
    }

    .hero-btns {
      display: flex;
      align-items: center;
      gap: 16px;
      flex-wrap: wrap;
      animation: fadeUp .7s .22s var(--ease-out) both;
    }

    /* ─────────────────────────────────────
       BUTTONS (global)
    ───────────────────────────────────── */
    .btn-primary {
      display: inline-flex;
      align-items: center;
      gap: 10px;
      background: var(--charcoal);
      color: var(--ivory);
      font-family: var(--f-body);
      font-size: 11px;
      font-weight: 600;
      letter-spacing: .16em;
      text-transform: uppercase;
      padding: 16px 32px;
      border-radius: 2px;
      transition: background .2s, transform .15s, box-shadow .2s;
    }
    .btn-primary:hover {
      background: var(--ink-2);
      transform: translateY(-1px);
      box-shadow: var(--shadow-md);
    }

    .btn-gold {
      display: inline-flex;
      align-items: center;
      gap: 10px;
      background: var(--gold);
      color: var(--ivory);
      font-family: var(--f-body);
      font-size: 11px;
      font-weight: 600;
      letter-spacing: .16em;
      text-transform: uppercase;
      padding: 16px 32px;
      border-radius: 2px;
      transition: background .2s, transform .15s, box-shadow .2s;
    }
    .btn-gold:hover {
      background: var(--gold-dk);
      transform: translateY(-1px);
      box-shadow: 0 8px 28px rgba(184,150,78,.3);
    }

    .btn-outline {
      display: inline-flex;
      align-items: center;
      gap: 10px;
      background: transparent;
      color: var(--ink);
      font-family: var(--f-body);
      font-size: 11px;
      font-weight: 500;
      letter-spacing: .14em;
      text-transform: uppercase;
      padding: 15px 28px;
      border-radius: 2px;
      border: 1px solid var(--rule);
      transition: border-color .2s, color .2s;
    }
    .btn-outline:hover {
      border-color: var(--gold);
      color: var(--gold-dk);
    }

    /* ─────────────────────────────────────
       WISE BADGE
    ───────────────────────────────────── */
    .wise-badge {
      display: inline-flex;
      align-items: center;
      gap: 9px;
      background: var(--ivory-2);
      border: 1px solid var(--rule-lt);
      border-radius: 4px;
      padding: 8px 14px;
      font-size: 11px;
      font-weight: 500;
      color: var(--mist);
      letter-spacing: .04em;
    }
    .wise-badge .lock-icon {
      width: 12px;
      height: 12px;
      color: var(--gold);
    }
    .wise-badge strong {
      color: var(--ink-2);
      font-weight: 600;
    }
    .wise-badge .payment-icons {
      display: flex;
      align-items: center;
      gap: 5px;
      margin-left: 4px;
    }
    .pay-chip {
      background: var(--charcoal);
      color: var(--ivory);
      font-size: 8.5px;
      font-weight: 700;
      letter-spacing: .05em;
      padding: 2px 6px;
      border-radius: 2px;
      line-height: 1.4;
    }
    .pay-chip.apple { background: #1C1A18; }
    .pay-chip.visa  { background: #1A1F71; }
    .pay-chip.mc    { background: #EB001B; }

    /* hero decorative image panel */
    .hero-panel {
      position: absolute;
      right: 0;
      top: 0;
      bottom: 0;
      width: 40%;
      display: flex;
      align-items: center;
      justify-content: center;
      animation: fadeIn .9s .4s both;
    }
    .hero-panel-inner {
      width: 85%;
      height: 70%;
      background:
        linear-gradient(135deg, var(--parch) 0%, var(--ivory-2) 100%);
      border-radius: 3px;
      border: 1px solid var(--rule-lt);
      box-shadow: var(--shadow-lg);
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      gap: 12px;
      position: relative;
      overflow: hidden;
    }
    .hero-panel-inner::before {
      content: '';
      position: absolute;
      inset: 0;
      background:
        radial-gradient(ellipse 80% 60% at 50% 30%, rgba(184,150,78,.08), transparent);
    }
    .hero-product-icon {
      font-size: 72px;
      filter: drop-shadow(0 8px 24px rgba(28,26,24,.12));
      position: relative;
    }
    .hero-product-label {
      font-family: var(--f-display);
      font-size: 15px;
      font-weight: 500;
      color: var(--ink-2);
      letter-spacing: .06em;
      position: relative;
    }
    .hero-product-sub {
      font-size: 11px;
      font-weight: 400;
      letter-spacing: .12em;
      text-transform: uppercase;
      color: var(--mist);
      position: relative;
    }

    /* floating stat cards */
    .stat-card {
      position: absolute;
      background: white;
      border-radius: 6px;
      padding: 12px 16px;
      box-shadow: var(--shadow-md);
      font-family: var(--f-body);
    }
    .stat-card.s1 { bottom: 14%; left: -8%; }
    .stat-card.s2 { top: 14%; right: -5%; }
    .stat-num {
      font-family: var(--f-display);
      font-size: 22px;
      font-weight: 600;
      color: var(--charcoal);
      line-height: 1;
    }
    .stat-label {
      font-size: 10px;
      font-weight: 500;
      letter-spacing: .1em;
      text-transform: uppercase;
      color: var(--mist);
      margin-top: 3px;
    }

    /* ─────────────────────────────────────
       SECTION SCAFFOLDING
    ───────────────────────────────────── */
    section { padding: 100px 6%; }

    .sec-kicker {
      font-size: 10px;
      font-weight: 600;
      letter-spacing: .24em;
      text-transform: uppercase;
      color: var(--gold);
      margin-bottom: 14px;
      display: flex;
      align-items: center;
      gap: 12px;
    }
    .sec-kicker::after {
      content: '';
      display: block;
      width: 36px;
      height: 1px;
      background: var(--gold);
    }

    .sec-h2 {
      font-family: var(--f-display);
      font-weight: 400;
      font-size: clamp(32px, 4.5vw, 52px);
      line-height: 1.1;
      color: var(--charcoal);
      margin-bottom: 16px;
    }
    .sec-h2 em { font-style: italic; color: var(--gold-dk); }

    .sec-sub {
      font-size: 15px;
      font-weight: 300;
      color: var(--ink-2);
      max-width: 480px;
      line-height: 1.8;
    }

    /* section divider rule */
    .rule {
      border: none;
      border-top: 1px solid var(--rule-lt);
      margin: 0 6%;
    }

    /* ─────────────────────────────────────
       PRODUCT GRID
    ───────────────────────────────────── */
    #products {
      background: var(--ivory);
    }

    .products-header {
      max-width: 640px;
      margin-bottom: 64px;
    }

    .products-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 24px;
    }

    .prod-card {
      background: white;
      border-radius: 4px;
      border: 1px solid var(--rule-lt);
      overflow: hidden;
      transition: box-shadow .3s, transform .3s;
      display: flex;
      flex-direction: column;
    }
    .prod-card:hover {
      box-shadow: var(--shadow-lg);
      transform: translateY(-4px);
    }

    .prod-image {
      background: var(--parch);
      height: 200px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 64px;
      position: relative;
      overflow: hidden;
      border-bottom: 1px solid var(--rule-lt);
    }
    .prod-image::after {
      content: '';
      position: absolute;
      inset: 0;
      background: radial-gradient(ellipse 80% 80% at 50% 40%, rgba(184,150,78,.07), transparent);
    }

    .prod-badge {
      position: absolute;
      top: 12px;
      left: 12px;
      font-size: 9px;
      font-weight: 700;
      letter-spacing: .12em;
      text-transform: uppercase;
      background: var(--charcoal);
      color: var(--ivory);
      padding: 4px 10px;
      border-radius: 2px;
      z-index: 1;
    }
    .prod-badge.gold { background: var(--gold); }

    .prod-body {
      padding: 24px 22px;
      flex: 1;
      display: flex;
      flex-direction: column;
    }

    .prod-cat {
      font-size: 10px;
      font-weight: 600;
      letter-spacing: .18em;
      text-transform: uppercase;
      color: var(--mist);
      margin-bottom: 6px;
    }

    .prod-name {
      font-family: var(--f-display);
      font-size: 19px;
      font-weight: 500;
      color: var(--charcoal);
      line-height: 1.25;
      margin-bottom: 8px;
    }

    .prod-desc {
      font-size: 13px;
      font-weight: 300;
      color: var(--ink-2);
      line-height: 1.65;
      margin-bottom: 20px;
      flex: 1;
    }

    .prod-footer {
      border-top: 1px solid var(--rule-lt);
      padding-top: 18px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 12px;
    }

    .prod-price {
      font-family: var(--f-display);
      font-size: 22px;
      font-weight: 500;
      color: var(--charcoal);
    }
    .prod-price-note {
      font-size: 11px;
      color: var(--mist);
      margin-top: 1px;
      font-weight: 300;
    }

    /* product checkout button */
    .prod-cta {
      display: inline-flex;
      align-items: center;
      gap: 7px;
      background: var(--charcoal);
      color: var(--ivory);
      font-family: var(--f-body);
      font-size: 10px;
      font-weight: 600;
      letter-spacing: .14em;
      text-transform: uppercase;
      padding: 11px 18px;
      border-radius: 2px;
      white-space: nowrap;
      transition: background .2s, box-shadow .2s;
    }
    .prod-cta:hover {
      background: var(--ink-2);
      box-shadow: var(--shadow-sm);
    }
    .prod-cta svg { width: 11px; height: 11px; flex-shrink: 0; }

    /* wise badge under product */
    .prod-wise {
      display: flex;
      align-items: center;
      gap: 6px;
      margin-top: 12px;
      font-size: 11px;
      font-weight: 400;
      color: var(--mist-lt);
      letter-spacing: .02em;
    }
    .prod-wise svg { width: 12px; height: 12px; color: var(--gold); }

    /* ─────────────────────────────────────
       TRUST STRIP
    ───────────────────────────────────── */
    .trust-strip {
      background: var(--ivory-2);
      border-top: 1px solid var(--rule-lt);
      border-bottom: 1px solid var(--rule-lt);
      padding: 0 6%;
    }

    .trust-items {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      divide-x: 1px solid var(--rule-lt);
    }

    .trust-item {
      display: flex;
      align-items: center;
      gap: 14px;
      padding: 32px 24px;
      border-right: 1px solid var(--rule-lt);
    }
    .trust-item:last-child { border-right: none; }

    .trust-icon {
      width: 40px;
      height: 40px;
      border-radius: 50%;
      border: 1px solid var(--rule);
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 18px;
      flex-shrink: 0;
      background: white;
    }

    .trust-title {
      font-family: var(--f-display);
      font-size: 15px;
      font-weight: 500;
      color: var(--charcoal);
      margin-bottom: 2px;
      line-height: 1.2;
    }
    .trust-desc {
      font-size: 12px;
      font-weight: 300;
      color: var(--mist);
      line-height: 1.5;
    }

    /* ─────────────────────────────────────
       PAYMENT / WISE SECTION
    ───────────────────────────────────── */
    #payment {
      background: var(--charcoal);
      color: var(--ivory);
      position: relative;
      overflow: hidden;
    }
    #payment::before {
      content: '';
      position: absolute;
      inset: 0;
      background:
        radial-gradient(ellipse 60% 80% at 80% 50%, rgba(184,150,78,.08), transparent),
        radial-gradient(ellipse 40% 40% at 10% 20%, rgba(184,150,78,.05), transparent);
    }
    #payment .sec-h2 { color: var(--ivory); }
    #payment .sec-sub { color: var(--mist-lt); max-width: 520px; }
    #payment .sec-kicker { color: var(--gold-lt); }
    #payment .sec-kicker::after { background: var(--gold-dk); }

    .payment-layout {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 80px;
      align-items: center;
      position: relative;
      z-index: 1;
    }

    .payment-card {
      background: rgba(250,247,242,.06);
      border: 1px solid rgba(184,150,78,.2);
      border-radius: 6px;
      padding: 44px;
      position: relative;
      overflow: hidden;
    }
    .payment-card::before {
      content: '';
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      height: 2px;
      background: linear-gradient(90deg, transparent, var(--gold), transparent);
    }

    .payment-card-title {
      font-family: var(--f-display);
      font-size: 26px;
      font-weight: 500;
      color: var(--ivory);
      margin-bottom: 6px;
    }
    .payment-card-sub {
      font-size: 13px;
      font-weight: 300;
      color: var(--mist-lt);
      margin-bottom: 32px;
    }

    .payment-methods {
      display: flex;
      flex-direction: column;
      gap: 12px;
      margin-bottom: 32px;
    }
    .pay-method {
      display: flex;
      align-items: center;
      gap: 14px;
      padding: 14px 18px;
      background: rgba(250,247,242,.05);
      border: 1px solid rgba(250,247,242,.08);
      border-radius: 4px;
      font-size: 14px;
      font-weight: 400;
      color: var(--ivory);
      transition: border-color .2s;
